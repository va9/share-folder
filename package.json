		"@typescript-eslint/parser": "5.29.0",
		"browser-image-compression": "^2.0.2",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.25.0",
		"eslint": "^8.49.0",
		"eslint-config-standard": "^17.1.0",
		"obsidian": "latest",
		"obsidian-typings": "^4.68.0",
		"tslib": "2.4.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
