{
	"name": "obsidian-publish-folder",
	"version": "0.1.0",
	"description": "Publish an entire folder as a navigable website with sidebar navigation, backlinks, search, and tag pages.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
